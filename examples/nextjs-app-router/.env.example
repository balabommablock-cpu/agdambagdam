# Public values — safe to expose in the browser.
NEXT_PUBLIC_ABACUS_API_KEY=demo-public-key
NEXT_PUBLIC_ABACUS_BASE_URL=https://boredfolio.com/agdambagdam/api

# Server-only values — keep secret. These are used in Server Components.
# If you don't set them, the NEXT_PUBLIC_* values above are used as fallbacks.
ABACUS_API_KEY=demo-public-key
ABACUS_BASE_URL=https://boredfolio.com/agdambagdam/api
